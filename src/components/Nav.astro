---
import methGif from "../assets/meth.gif";
import mathGif from "../assets/math.gif";
const links = [
  { href: "/", label: "Home" },
  { href: "/music", label: "Music" },
  { href: "/feed", label: "Fan feed" },
];
const current = Astro.url.pathname;
---

<header>
  <nav class="container">
    <a href="/" class="logo">
      <img src={methGif.src} alt="Meth" />
      <img src={mathGif.src} alt="Math" />
    </a>
    <ul>
      {links.map(l => (
        <li>
          <a href={l.href} class={current === l.href ? "active" : ""}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .logo { display: flex; align-items: center; gap: 4px; }
  .logo img { height: 40px; width: auto; display: block; }
  ul { display: flex; gap: 32px; list-style: none; }
  a { font-size: 14px; color: var(--muted); transition: color .15s; }
  a:hover, a.active { color: var(--text); }
</style>