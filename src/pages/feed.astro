---
import Base from "../layouts/Base.astro";
import FanFeed from "../components/FanFeed.astro";
import UploadForm from "../components/UploadForm.astro";
---

<Base title="Fan feed">
  <section class="section">
    <div class="container">
      <p class="section-label">Community</p>
      <h1 class="section-title">Fan feed</h1>
      <p class="intro">Shot something at one of our gigs? Share it here. Photos and short videos welcome — we review everything before it goes live.</p>
      <UploadForm />
      <FanFeed />
    </div>
  </section>
</Base>

<style>
  .intro { color: var(--muted); font-size: 15px; max-width: 560px; margin-bottom: 48px; }
</style>