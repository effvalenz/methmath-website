---
import Base from "../layouts/Base.astro";
import FanFeed from "../components/FanFeed.astro";
import UploadForm from "../components/UploadForm.astro";
---

<Base title="Fan feed">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Recuerdos</h1>
      <p class="intro">¿Capturaste algún recuerdo en uno de nuestros conciertos? Compártelo aquí. Fotos y videos cortos.</p>
      <UploadForm />
      <FanFeed />
    </div>
  </section>
</Base>

<style>
  .intro { color: var(--muted); font-size: 15px; max-width: 560px; margin-bottom: 48px; }
</style>