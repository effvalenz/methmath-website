---
import Base from "../layouts/Base.astro";
---

<Base title="Música">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Discografía</h1>
      <div class="releases">
        <iframe data-testid="embed-iframe" style="border-radius:12px;border:0" src="https://open.spotify.com/embed/album/7qOzDSLLeR5imM68K69hTw?utm_source=generator&theme=0" width="100%" height="152" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        <iframe data-testid="embed-iframe" style="border-radius:12px;border:0" src="https://open.spotify.com/embed/album/0evBuyhqf12uiAa4tG0lZJ?utm_source=generator&theme=0" width="100%" height="152" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
        <iframe data-testid="embed-iframe" style="border-radius:12px;border:0" src="https://open.spotify.com/embed/album/2lvzoRYpLcIkXSa1wc9Erm?utm_source=generator&theme=0" width="100%" height="152" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      </div>
    </div>
  </section>
</Base>

<style>
  .releases { display: flex; flex-direction: column; gap: 12px; }
</style>